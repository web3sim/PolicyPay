{
  "name": "policypay",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "policypay",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*",
        "agents/*"
      ]
    },
    "apps/api": {
      "name": "@policypay/api",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@policypay/web",
      "version": "0.1.0"
    },
    "node_modules/@policypay/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@policypay/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@policypay/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/contracts": {
      "name": "@policypay/contracts",
      "version": "0.1.0"
    }
  }
}
